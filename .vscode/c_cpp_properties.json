{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/Firmware/Board",
                "${workspaceFolder}/Firmware/Board/Core/Inc",
                "${workspaceFolder}/Firmware/Board/Drivers/STM32F4xx_HAL_Driver/Inc",
                "${workspaceFolder}/Firmware/Board/Middlewares/Third_Party/FreeRTOS/Source/CMSIS_RTOS_V2",
                "${workspaceFolder}/Firmware/Board/Middlewares/Third_Party/FreeRTOS/Source/include",
                "${workspaceFolder}/Firmware/Board/Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4F",
                "${workspaceFolder}/Firmware/Communication",
                "${workspaceFolder}/Firmware/Communication/can",
                "${workspaceFolder}/Firmware/Interface",
                "${workspaceFolder}/Firmware/Task"
            ],
            "defines": [
                "USE_HAL_DRIVER",
                "STM32F405xx",
                "DEBUG"
            ],
            "compilerPath": "/usr/bin/arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-gcc-arm",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}
